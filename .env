# ====== KUNCI RAHASIA SESSION (WAJIB) ======
# Dipakai untuk enkripsi cookie session login. Ganti dengan string acak sendiri.
SECRET_KEY=Zahra_DSS_2026_Random_Key_123456789

# ====== GOOGLE LOGIN (OAuth 2.0) ======
# Ambil dari Google Cloud Console > APIs & Services > Credentials
# Lihat PANDUAN_LOGIN.md untuk langkah lengkap.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ====== MICROSOFT LOGIN (Azure AD / Entra ID) ======
# Ambil dari Azure Portal > App registrations
# Lihat PANDUAN_LOGIN.md untuk langkah lengkap.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# "common" = boleh login pakai akun Microsoft pribadi ATAU akun kerja/sekolah.
# Ganti dengan Tenant ID kalau mau batasi hanya 1 organisasi tertentu.
MICROSOFT_TENANT_ID=common

# ====== DATABASE (opsional, lihat PANDUAN.md) ======
# DATABASE_URL=postgresql://...
